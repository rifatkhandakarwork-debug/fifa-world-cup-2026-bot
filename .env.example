BOT_TOKEN=your_telegram_bot_token
DATABASE_PATH=worldcup_bot.sqlite3
TIMEZONE=Asia/Dhaka

# Official FIFA public API. Do not change unless FIFA changes their endpoint.
FIFA_CALENDAR_URL=https://api.fifa.com/api/v3/calendar/matches
FIFA_COMPETITION_ID=17

# Reliable fallback for live scoreboard if FIFA is temporarily unavailable.
ESPN_SCOREBOARD_URL=https://site.api.espn.com/apis/site/v2/sports/soccer/fifa.world/scoreboard

# Optional RSS feeds for latest news.
NEWS_FEEDS=https://news.google.com/rss/search?q=%22FIFA%20World%20Cup%202026%22&hl=en-US&gl=US&ceid=US:en
